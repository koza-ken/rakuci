<%# 既存のアイテム要素を新しい HTML で置き換え（名前編集時） %>
<% delete_path = @schedule.present? ? schedule_packing_list_item_path(@schedule, @packing_item) : packing_list_item_path(@packing_item) %>
<%= turbo_stream.replace "packing_item_#{@packing_item.id}" do %>
  <%= render "shared/packing_items/packing_item", packing_item: @packing_item, item_delete_path: delete_path %>
<% end %>
