<% if @saved_item.present? %>
  <%# 新規アイテムをリストに追加 %>
  <% delete_path = @schedule.present? ? schedule_packing_list_item_path(@schedule, @saved_item) : packing_list_item_path(@saved_item) %>
  <%= turbo_stream.append "packing-items-list" do %>
    <%= render "shared/packing_items/packing_item", packing_item: @saved_item, item_delete_path: delete_path %>
  <% end %>

  <%# 空状態メッセージを削除（最初のアイテム追加時） %>
  <%= turbo_stream.remove "empty-state" %>

  <%# フォームをリセット＆非表示化 %>
  <% form_url = @schedule.present? ? schedule_packing_list_items_path(@schedule) : packing_list_items_path %>
  <%= turbo_stream.replace "packing-item-form" do %>
    <div id="packing-item-form" class="hidden mb-6" data-packing-list-form-target="form">
      <%= render "shared/packing_lists/packing_item_form", packing_list: @packing_list, packing_item: @packing_item, form_url: form_url, input_class: "" %>
    </div>
  <% end %>
<% else %>
  <%# エラー時はフォームを表示してエラーメッセージを表示 %>
  <% form_url = @schedule.present? ? schedule_packing_list_items_path(@schedule) : packing_list_items_path %>
  <%= turbo_stream.replace "packing-item-form" do %>
    <div id="packing-item-form" class="mb-6" data-packing-list-form-target="form">
      <%= render "shared/packing_lists/packing_item_form", packing_list: @packing_list, packing_item: @packing_item, form_url: form_url, input_class: "" %>
    </div>
  <% end %>
<% end %>
