<%= render layout: "shared/modal_wrapper", locals: { frame_id: "schedule-create-modal" } do %>
  <div class="w-full max-w-md">
    <h2 class="text-xl font-bold text-text mb-6"><%= t('groups.schedules.new.title') %></h2>
  </div>

  <%= form_with model: [@group, @schedule], url: group_schedule_path(@group), local: true, class: "w-full max-w-md" do |f| %>
    <div class="mb-4">
      <%= f.label :name, class: "block text-sm font-medium text-text mb-2" do %>
        <%= t('users.schedules.form.name_label') %>
        <span class="text-red-600 font-bold ml-1">*</span>
      <% end %>
      <%= f.text_field :name, class: "form-text-field w-full", placeholder: t('users.schedules.form.name_placeholder') %>
      <% @schedule.errors.full_messages_for(:name).each do |message| %>
        <p class="text-red-600 text-xs ml-2"><%= message %></p>
      <% end %>
    </div>

    <div class="mb-4">
      <%= f.label :start_date, class: "block text-sm font-medium text-text mb-2" %>
      <%= f.date_field :start_date, class: "form-text-field w-full" %>
      <% @schedule.errors.full_messages_for(:start_date).each do |message| %>
        <p class="text-red-600 text-xs ml-2"><%= message %></p>
      <% end %>
    </div>

    <div class="mb-6">
      <%= f.label :end_date, class: "block text-sm font-medium text-text mb-2" %>
      <%= f.date_field :end_date, class: "form-text-field w-full" %>
      <% @schedule.errors.full_messages_for(:end_date).each do |message| %>
        <p class="text-red-600 text-xs ml-2"><%= message %></p>
      <% end %>
    </div>

    <div class="flex gap-2">
      <%= f.submit t('users.schedules.form.submit'), class: "btn-main px-4 py-2 flex-1" %>
      <button type="button" class="btn-sub px-4 py-2 w-auto flex-1" data-action="click->modal#close">
        <%= t('users.schedules.form.cancel') %>
      </button>
    </div>
  <% end %>
<% end %>
