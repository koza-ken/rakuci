<main class="flex flex-col items-center justify-center px-8 md:px-6 lg:px-8 py-12">
  <div class="w-full max-w-2xl md:max-w-3xl lg:max-w-4xl">
    <h1 class="text-xl lg:text-2xl text-text font-bold mb-8 lg:mb-16"><%= t('groups.schedules.edit.title') %></h1>

    <%= form_with model: [@group, @schedule], url: group_schedule_path(@group), local: true do |f| %>
      <%# schedulesコントローラで更新時の遷移先を分けるためにfrom_pageを定義している %>
      <%= f.hidden_field :from_page, value: "edit" %>
      <div class="mb-6">
        <%= f.label :name, class: "block text-sm lg:text-base font-medium text-text mb-2" do %>
          <%= t('activerecord.attributes.schedule.name') %>
          <span class="text-red-600 font-bold ml-1">*</span>
        <% end %>
        <%= f.text_field :name, class: "form-text-field w-full", placeholder: t('users.schedules.form.name_placeholder') %>
        <% @schedule.errors.full_messages_for(:name).each do |message| %>
          <p class="text-red-600 text-xs ml-2"><%= message %></p>
        <% end %>
      </div>

      <div class="flex flex-col lg:flex-row gap-4 lg:gap-6 mb-6">
        <div class="flex-1">
          <%= f.label :start_date, class: "block text-sm lg:text-base font-medium text-text mb-2" %>
          <%= f.date_field :start_date, class: "form-text-field w-full" %>
          <% @schedule.errors.full_messages_for(:start_date).each do |message| %>
            <p class="text-red-600 text-xs ml-2"><%= message %></p>
          <% end %>
        </div>

        <div class="flex-1">
          <%= f.label :end_date, class: "block text-sm lg:text-base font-medium text-text mb-2" %>
          <%= f.date_field :end_date, class: "form-text-field w-full" %>
          <% @schedule.errors.full_messages_for(:end_date).each do |message| %>
            <p class="text-red-600 text-xs ml-2"><%= message %></p>
          <% end %>
        </div>
      </div>

      <div class="mb-6">
        <%= f.label :memo, class: "block text-sm lg:text-base font-medium text-text mb-2" %>
        <%= f.text_area :memo, class: "form-text-field w-full resize-none min-h-[100px]", placeholder: t('schedules.form.memo_placeholder') %>
      </div>

      <div class="flex gap-3">
        <%= f.submit t('users.schedules.form.update'), class: "btn-main flex-1 text-center" %>
        <%= link_to t('users.schedules.form.cancel'), group_schedule_path(@group), class: "btn-sub flex-1 text-center" %>
      </div>
    <% end %>
  </div>
</main>
