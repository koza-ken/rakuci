<%= render layout: "shared/modal_wrapper", locals: { frame_id: "group-create-modal" } do %>
  <div class="w-full max-w-md">
    <h2 class="text-xl font-bold text-text mb-6"><%= t('groups.new.title') %></h2>
  </div>

  <%= form_with model: @form, url: groups_path, class: "w-full max-w-md" do |f| %>
    <%# グループ名 %>
    <div class="mb-6">
      <%= f.label :name, class: "block text-sm font-medium text-text mb-2" do %>
        <%= t('groups.form.name') %>
        <span class="text-red-600 font-bold ml-1">*</span>
      <% end %>
      <%= f.text_field :name, placeholder: t('groups.form.name_placeholder'), autofocus: true, class: "form-text-field" %>

      <%# エラーメッセージ %>
      <% @form.errors.full_messages_for(:name).each do |message| %>
        <p class="text-red-600 text-xs ml-2"><%= message %></p>
      <% end %>
    </div>

    <%# グループでの名前 %>
    <div class="mb-6">
      <%= f.label :group_nickname, class: "block text-sm font-medium text-text mb-2" do %>
        <%= t('groups.form.group_nickname') %>
        <span class="text-red-600 font-bold ml-1">*</span>
      <% end %>
      <%= f.text_field :group_nickname, placeholder: t('groups.form.group_nickname_placeholder'), class: "form-text-field" %>

      <%# エラーメッセージ %>
      <% @form.errors.full_messages_for(:group_nickname).each do |message| %>
        <p class="text-red-600 text-xs ml-2"><%= message %></p>
      <% end %>
    </div>

    <%# ボタン %>
    <div class="flex gap-3 mt-12">
      <%= f.submit t('groups.form.submit'), class: "btn-main flex-1" %>
      <%= link_to t('groups.form.cancel'), groups_path, data: { action: "click->modal#close" }, class: "btn-sub flex-1 text-center" %>
    </div>
  <% end %>
<% end %>
