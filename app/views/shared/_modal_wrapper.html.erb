<%# モーダルの共通ラッパー %>
<%# frame_id: turbo-frameのID（例: "card-create-modal"） %>
<%= turbo_frame_tag frame_id, data: { controller: "modal" } do %>
  <div role="dialog" tabindex="-1" class="fixed inset-0 z-60 flex items-center justify-center w-full h-screen p-2">
    <%# 背景（クリックでモーダルを閉じる） %>
    <div data-action="click->modal#close" class="fixed inset-0 block w-full h-screen cursor-pointer bg-gray-900/30"></div>
    <div class="relative z-20 w-full max-w-2xl max-h-screen overflow-y-auto bg-main-bg rounded-md">
      <main class="flex flex-col items-center justify-center px-8 py-12">
        <%= yield %>
      </main>
    </div>
  </div>
<% end %>
