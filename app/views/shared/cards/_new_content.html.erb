<%= render layout: "shared/modal_wrapper", locals: { frame_id: "card-create-modal" } do %>
  <div class="w-full max-w-md">
    <h2 class="text-xl font-bold text-text mb-6"><%= t('cards.new.title') %></h2>
  </div>

  <%= form_with model: @card, url: (@group ? group_cards_path(@group) : cards_path), class: "w-full max-w-md" do |f| %>
    <%# カード名 %>
    <div class="mb-6">
      <%= f.label :name, class: "block text-sm font-medium text-text mb-2" do %>
        <%= t('cards.form.name') %>
        <span class="text-red-600 font-bold ml-1">*</span>
      <% end %>
      <%= f.text_field :name,
          placeholder: t('cards.form.name_placeholder'),
          class: "form-text-field" %>
      <% @card.errors.full_messages_for(:name).each do |message| %>
        <p class="text-red-600 text-xs ml-2"><%= message %></p>
      <% end %>
    </div>

    <%# メモ %>
    <div class="mb-6">
      <%= f.label :memo, t('cards.form.memo'), class: "block text-sm font-medium text-text mb-2" %>
      <%= f.text_area :memo,
          rows: 5,
          class: "form-text-field resize-vertical" %>
      <% @card.errors.full_messages_for(:memo).each do |message| %>
        <p class="text-red-600 text-xs ml-2"><%= message %></p>
      <% end %>
    </div>

    <%# ボタン %>
    <div class="flex gap-3">
      <%= f.submit t('cards.form.submit'), class: "btn-main flex-1" %>
      <%= link_to t('cards.form.cancel'), :back, data: { action: "click->modal#close" }, class: "btn-sub flex-1 text-center" %>
    </div>
  <% end %>
<% end %>
